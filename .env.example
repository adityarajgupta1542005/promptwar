# VoteSmart AI — Environment Configuration
# GCP Project: promptwarhack2skil
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────────
# NO API keys belong here. The frontend calls /api/* which nginx
# proxies to Cloud Functions in production, and Vite proxies in dev.
#
# Optional: override the API base URL (default is /api which uses the proxy)
# VITE_API_URL=/api
#
# App metadata (non-secret)
VITE_APP_NAME=VoteSmart AI
#
# ─────────────────────────────────────────────────────────────
# BACKEND (Firebase/Cloud Functions)
# ─────────────────────────────────────────────────────────────
# Set the Gemini API key as a secret on the backend only.
#
# Option A — Firebase Functions environment (Gen2):
#   Set in Google Cloud Secret Manager, then reference in functions/index.js
#   via process.env.GEMINI_API_KEY (already done)
#
# Option B — For local function emulation, create functions/.env:
#   GEMINI_API_KEY=your_gemini_api_key_here
#
# Get your free key at: https://aistudio.google.com/apikey
#
# Option C — Cloud Run (if deploying backend as Cloud Run service):
#   gcloud run deploy ... --set-env-vars GEMINI_API_KEY=your_key
#
# ─────────────────────────────────────────────────────────────
# GCP Project info (reference only — not used at runtime)
# ─────────────────────────────────────────────────────────────
# GCP_PROJECT_ID=promptwarhack2skil
# CLOUD_FUNCTIONS_REGION=asia-south1
# CLOUD_RUN_REGION=asia-south1
