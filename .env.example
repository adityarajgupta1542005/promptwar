# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VoteSmart AI — Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# FRONTEND — No API keys needed!
# The frontend calls /api/* endpoints that proxy to Cloud Functions.
# API keys live ONLY on the server side (Firebase Functions).
#
# BACKEND (Firebase Functions)
# Set these in your Firebase project:
#   firebase functions:config:set gemini.api_key="YOUR_KEY"
# Or for Gen2 functions, set as environment variable:
#   GEMINI_API_KEY=your_gemini_api_key_here
#
# Get your free Gemini API key at: https://aistudio.google.com/apikey
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Optional: App metadata (not secret)
VITE_APP_NAME=VoteSmart AI
