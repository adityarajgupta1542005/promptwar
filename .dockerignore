src/**/__tests__
src/test
**/*.test.js
**/*.test.jsx
**/*.spec.js
**/*.spec.jsx
coverage

# Scripts and docs
*.md
*.log
*.bat
*.sh
image-optimize.sh
setup-and-test.bat

# IDE
.vscode
.idea

# OS files
.DS_Store
Thumbs.db
